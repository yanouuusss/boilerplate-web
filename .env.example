# Copier vers .env et remplir. Aucune valeur réelle dans ce fichier.
# Les clés Supabase se génèrent avec : node scripts/generate-supabase-keys.mjs

# Serveur
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info

# Base de données (Postgres de la stack Supabase, docker-compose)
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/postgres

# Supabase (auth + storage via Kong — le navigateur n'y accède jamais directement)
SUPABASE_URL=http://127.0.0.1:8000
JWT_SECRET=CHANGE_ME
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
