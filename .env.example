# Copier vers .env et remplir. Aucune valeur réelle dans ce fichier.

# Serveur
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info

# Base de données (Postgres de la stack Supabase, docker-compose)
DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/postgres

# Supabase (auth + storage — le navigateur n'y accède jamais directement)
SUPABASE_URL=http://127.0.0.1:8000
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
