{
  "name": "boilerplate-web",
  "version": "0.1.0",
  "description": "Boilerplate web : TypeScript strict, Fastify, HTMX + Alpine.js, Supabase auto-hébergé, Drizzle, Zod",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "start": "node dist/server/index.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/copy-vendor.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@fastify/helmet": "^13.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/view": "^12.0.0",
    "alpinejs": "^3.15.12",
    "eta": "^4.6.0",
    "fastify": "^5.10.0",
    "htmx.org": "^2.0.10",
    "zod": "^4.4.3"
  }
}
